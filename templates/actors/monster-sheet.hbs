<form class="{{cssClass}} deepshadow-sheet monster-sheet" autocomplete="off">
  <header class="sheet-header">
    <img
      class="profile-img"
      src="{{actor.img}}"
      data-edit="img"
      title="{{actor.name}}"
      alt="{{actor.name}}"
      height="128"
      width="128"
    />

    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Monster Name" />
      </h1>

      <div class="monster-meta-grid">
        <label class="meta-field">
          <span>Archetype</span>
          <input
            name="system.profile.archetype"
            type="text"
            value="{{profile.archetype}}"
            placeholder="Gnoll, Troll, Zombie..."
          />
        </label>

        <label class="meta-field">
          <span>Classification</span>
          <input
            name="system.profile.classification"
            type="text"
            value="{{profile.classification}}"
            placeholder="Humanoid, Beast, Undead..."
          />
        </label>

        <label class="meta-field">
          <span>XP Reward</span>
          <input
            name="system.rewards.xp"
            type="number"
            value="{{rewards.xp}}"
            min="0"
            step="1"
          />
        </label>
      </div>

      <div class="condition-row">
        <label class="checkbox-field">
          <input
            type="checkbox"
            name="system.profile.animal"
            {{checked profile.animal}}
          />
          <span>Animal</span>
        </label>

        <label class="checkbox-field">
          <input
            type="checkbox"
            name="system.profile.undead"
            {{checked profile.undead}}
          />
          <span>Undead</span>
        </label>

        <label class="checkbox-field">
          <input
            type="checkbox"
            name="system.profile.large"
            {{checked profile.large}}
          />
          <span>Large</span>
        </label>

        <label class="checkbox-field">
          <input
            type="checkbox"
            name="system.profile.flying"
            {{checked profile.flying}}
          />
          <span>Flying</span>
        </label>

        <label class="checkbox-field">
          <input
            type="checkbox"
            name="system.conditions.poisoned"
            {{checked conditions.poisoned}}
          />
          <span>Poisoned</span>
        </label>

        <label class="checkbox-field">
          <input
            type="checkbox"
            name="system.conditions.diseased"
            {{checked conditions.diseased}}
          />
          <span>Diseased</span>
        </label>
      </div>

      {{#if tags.length}}
        <div class="tag-row">
          {{#each tags as |tag|}}
            <span class="monster-tag">{{tag}}</span>
          {{/each}}
        </div>
      {{/if}}
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="stats">Stats</a>
    <a class="item" data-tab="abilities">Abilities</a>
    <a class="item" data-tab="notes">Notes</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="stats">
      <section class="sheet-panel">
        <h2>Attributes</h2>

        <div class="attribute-grid">
          {{#each attributes as |attribute|}}
            <div class="attribute-card">
              <div class="attribute-header">
                <h3>{{attribute.label}}</h3>
                <a
                  class="rollable"
                  data-roll-type="attribute"
                  data-roll-key="{{attribute.key}}"
                  data-roll-label="{{attribute.label}}"
                  title="Roll {{attribute.label}}"
                >
                  <i class="fas fa-dice-d20"></i>
                </a>
              </div>

              <div class="attribute-values">
                <label>
                  <span>Current</span>
                  <input
                    name="system.attributes.{{attribute.key}}.value"
                    type="number"
                    value="{{attribute.value}}"
                    step="1"
                  />
                </label>

                <label>
                  <span>Base</span>
                  <input
                    name="system.attributes.{{attribute.key}}.base"
                    type="number"
                    value="{{attribute.base}}"
                    step="1"
                  />
                </label>
              </div>
            </div>
          {{/each}}
        </div>
      </section>

      <section class="sheet-panel">
        <h2>Skill Rolls</h2>

        {{#if hasAnySkills}}
          <table class="skills-table">
            <thead>
              <tr>
                <th>Skill</th>
                <th>Current</th>
                <th>Base</th>
                <th>Roll</th>
              </tr>
            </thead>
            <tbody>
              {{#each skillsList as |skill|}}
                {{#if skill.value}}
                  <tr>
                    <td>{{skill.label}}</td>
                    <td>
                      <input
                        name="system.skills.{{skill.key}}.value"
                        type="number"
                        value="{{skill.value}}"
                        step="1"
                      />
                    </td>
                    <td>
                      <input
                        name="system.skills.{{skill.key}}.base"
                        type="number"
                        value="{{skill.base}}"
                        step="1"
                      />
                    </td>
                    <td>
                      <a
                        class="rollable"
                        data-roll-type="skill"
                        data-roll-key="{{skill.key}}"
                        data-roll-label="{{skill.label}}"
                        title="Roll {{skill.label}}"
                      >
                        <i class="fas fa-dice-d20"></i>
                      </a>
                    </td>
                  </tr>
                {{/if}}
              {{/each}}
            </tbody>
          </table>
        {{else}}
          <p class="empty-state">This monster has no tracked skill bonuses yet.</p>
        {{/if}}
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="abilities">
      <section class="sheet-panel">
        <div class="section-header">
          <h2>Features & Traits</h2>
          <div class="section-controls">
            <a class="item-create" data-item-type="trait" title="Create Trait">
              <i class="fas fa-plus"></i> Trait
            </a>
            <a class="item-create" data-item-type="spell" title="Create Spell">
              <i class="fas fa-plus"></i> Spell
            </a>
            <a class="item-create" data-item-type="skill" title="Create Skill Item">
              <i class="fas fa-plus"></i> Skill
            </a>
            <a class="item-create" data-item-type="heroic" title="Create Special Ability">
              <i class="fas fa-plus"></i> Ability
            </a>
          </div>
        </div>

        <ol class="item-list">
          {{#each featureItems as |item|}}
            <li class="item" data-item-id="{{item.id}}">
              <div class="item-name">
                <img src="{{item.img}}" title="{{item.name}}" alt="{{item.name}}" width="32" height="32" />
                <div class="item-text">
                  <h4>{{item.name}}</h4>
                  <div class="item-type">{{item.type}}</div>
                </div>
              </div>

              <div class="item-summary">
                {{item.system.notes}}
              </div>

              <div class="item-controls">
                <a class="item-edit" title="Edit Feature">
                  <i class="fas fa-edit"></i>
                </a>
                <a class="item-delete" title="Delete Feature">
                  <i class="fas fa-trash"></i>
                </a>
              </div>
            </li>
          {{else}}
            <li class="item empty">No monster abilities or traits yet.</li>
          {{/each}}
        </ol>
      </section>

      <section class="sheet-panel">
        <div class="section-header">
          <h2>Equipment</h2>
          <div class="section-controls">
            <a class="item-create" data-item-type="weapon" title="Create Weapon">
              <i class="fas fa-plus"></i> Weapon
            </a>
            <a class="item-create" data-item-type="armor" title="Create Armor">
              <i class="fas fa-plus"></i> Armor
            </a>
            <a class="item-create" data-item-type="item" title="Create Item">
              <i class="fas fa-plus"></i> Item
            </a>
          </div>
        </div>

        <ol class="item-list">
          {{#each inventoryItems as |item|}}
            <li class="item" data-item-id="{{item.id}}">
              <div class="item-name">
                <img src="{{item.img}}" title="{{item.name}}" alt="{{item.name}}" width="32" height="32" />
                <div class="item-text">
                  <h4>{{item.name}}</h4>
                  <div class="item-type">{{item.type}}</div>
                </div>
              </div>

              <div class="item-summary">
                {{item.system.notes}}
              </div>

              <div class="item-controls">
                <a class="item-edit" title="Edit Item">
                  <i class="fas fa-edit"></i>
                </a>
                <a class="item-delete" title="Delete Item">
                  <i class="fas fa-trash"></i>
                </a>
              </div>
            </li>
          {{else}}
            <li class="item empty">No equipment or carried items.</li>
          {{/each}}
        </ol>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="notes">
      <section class="sheet-panel">
        <h2>Notes</h2>
        <textarea
          name="system.notes"
          rows="18"
          placeholder="Special rules, scenario behavior, traits, attacks, and descriptive text."
        >{{note}}</textarea>
      </section>
    </div>
  </section>
</form>
